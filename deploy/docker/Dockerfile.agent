FROM node:22-bookworm AS build

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN npm install -g pnpm@10

WORKDIR /app

# Copy workspace config
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./

# Copy workspace packages and the agent app
COPY packages/ ./packages/
COPY apps/agent/ ./apps/agent/

# Install deps for agent and its workspace dependencies
RUN pnpm install --frozen-lockfile --filter=@siestai/agent...

# Build packages first, then the agent
RUN pnpm --filter=@siestai/tsconfig build 2>/dev/null; true
RUN pnpm --filter=@siestai/agent build

FROM node:22-bookworm

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN npm install -g pnpm@10

WORKDIR /app

COPY --from=build /app/package.json /app/pnpm-workspace.yaml /app/pnpm-lock.yaml /app/.npmrc ./
COPY --from=build /app/packages/ ./packages/
COPY --from=build /app/apps/agent/package.json ./apps/agent/
RUN pnpm install --frozen-lockfile --filter=@siestai/agent... --prod

COPY --from=build /app/apps/agent/dist ./apps/agent/dist

ARG UID=10001
RUN adduser \
    --disabled-password \
    --gecos "" \
    --home "/app" \
    --shell "/sbin/nologin" \
    --uid "${UID}" \
    appuser

RUN chown -R appuser:appuser /app
USER appuser

WORKDIR /app/apps/agent
RUN pnpm download-files

ENV NODE_ENV=production
CMD ["node", "dist/main.js", "start"]

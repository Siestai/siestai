# ============================================================
# Siestai — Environment Variables
# Copy to .env.local and fill in real values
# ============================================================

# --- Database (packages/db) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/siestai
POSTGRES_PASSWORD=postgres

# --- LiveKit ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# --- AI Providers ---
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- API (apps/api) ---
PORT=4200
BACKEND_URL=http://localhost:4200
FRONTEND_URL=http://localhost:3000
ARENA_INVITE_SECRET=your-random-32-char-secret-here

# --- Auth (Better Auth via apps/api) ---
BETTER_AUTH_URL=http://localhost:4200
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-secret-value
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# COOKIE_DOMAIN=.siestai.com  # Only needed in staging/production

# --- Web (apps/web) ---
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_API_URL=http://localhost:4200

# PostgreSQL
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/siestai

# AI
OPENAI_API_KEY=sk-...

# LiveKit (for arena)
LIVEKIT_ENVIRONMENT=cloud
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Google OAuth (Better Auth)
BETTER_AUTH_URL=https://api-staging.siestai.com
BETTER_AUTH_SECRET=generate-a-random-secret-here
COOKIE_DOMAIN=.siestai.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Tool OAuth (separate from user login OAuth)
GITHUB_TOOLS_CLIENT_ID=your-github-tools-client-id
GITHUB_TOOLS_CLIENT_SECRET=your-github-tools-client-secret
GOOGLE_TOOLS_CLIENT_ID=your-google-tools-client-id
GOOGLE_TOOLS_CLIENT_SECRET=your-google-tools-client-secret
TAVILY_API_KEY=tvly-your-tavily-api-key
AGENT_TOOL_SECRET=generate-a-random-secret-here

# Arena
ARENA_INVITE_SECRET=generate-a-random-secret-here
FRONTEND_URL=https://staging.siestai.com
